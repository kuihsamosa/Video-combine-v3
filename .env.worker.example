# ─────────────────────────────────────────────────────────────────────────────
#  Video Combiner — Worker Node environment
#  Copy to .env.worker and fill in your values.
#  This file lives on the WORKER machine (T440p), not the main Mac.
#
#  Windows: find your Mac's IP with:
#    ping <mac-hostname>.local
#    OR check on Mac: System Settings → Wi-Fi → Details
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# IP of the main Mac running ./start.sh
# Check on Mac with: ipconfig getifaddr en0
MAIN_SERVER_URL=http://192.168.0.169:8080

# Must match WORKER_SECRET in main Mac's .env (default is fine if you haven't changed it)
WORKER_SECRET=videocombine-worker

# ── Identity ──────────────────────────────────────────────────────────────────

# Name shown in the Workers panel in the UI
WORKER_ID=t440p

# How many jobs to run in parallel on this machine (T440p has 4 cores, 2 is safe)
WORKER_CAPACITY=2

# Port this worker's built-in file server listens on
# Main Mac will pull finished videos from http://<this-pc-ip>:8182/<filename>
# Make sure Windows Firewall allows inbound TCP on this port
SERVE_PORT=8182

# ── API Keys ──────────────────────────────────────────────────────────────────
# Worker uses its own keys — paste the same ones as the Mac, or different ones
GROQ_API_KEY=
GROQ_API_KEY_2=
PEXELS_API_KEY=

# ── OmniVoice TTS (optional) ──────────────────────────────────────────────────
# If you want TTS to run locally on the T440p instead of calling back to Mac.
# Leave blank to skip local TTS (worker will rely on script already having audio).
OMNIVOICE_PORT=8881

# ── Output directory (optional) ───────────────────────────────────────────────
# Windows path example — forward slashes or double-backslashes both work
# OUTPUT_DIR=C:/Users/samos/Videos/video-combine-output
