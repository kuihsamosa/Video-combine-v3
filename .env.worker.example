# ─────────────────────────────────────────────────────────────────────────────
#  Video Combiner — Worker Node environment
#  Copy to .env.worker and fill in your values.
#  This file lives on the WORKER machine (e.g. T440p), not the main server.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# IP/hostname of the main machine running server.js
# Find it with: ip route get 1 | awk '{print $7}' (on Mac: ipconfig getifaddr en0)
MAIN_SERVER_URL=http://192.168.0.169:8080

# Must match WORKER_SECRET on the main server (default: videocombine-worker)
WORKER_SECRET=videocombine-worker

# ── Identity ──────────────────────────────────────────────────────────────────

# Unique name shown in the UI
WORKER_ID=t440p

# How many jobs to run simultaneously on this machine
WORKER_CAPACITY=2

# Port this worker uses to serve finished video files back to the main machine
SERVE_PORT=8182

# ── API Keys (worker uses its own keys — can differ from main machine) ─────────
GROQ_API_KEY=
GROQ_API_KEY_2=
PEXELS_API_KEY=

# ── OmniVoice TTS ─────────────────────────────────────────────────────────────
# If TTS is running locally on this worker machine
OMNIVOICE_PORT=8881

# ── Output directory ─────────────────────────────────────────────────────────
# Where finished videos are written before the main machine downloads them
# OUTPUT_DIR=/home/user/video-combine/output
