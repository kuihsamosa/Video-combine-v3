# Stock Media API Keys
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here
UNSPLASH_API_KEY=your_unsplash_api_key_here
VIDEVO_API_KEY=your_videvo_api_key_here
COVERR_API_KEY=your_coverr_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# API Configuration
DEFAULT_PER_PAGE=20
MAX_PER_PAGE=100
DEFAULT_SOURCES=pexels,pixabay,unsplash

# Rate Limiting (requests per hour)
PEXELS_RATE_LIMIT=200
PIXABAY_RATE_LIMIT=100
UNSPLASH_RATE_LIMIT=50
VIDEVO_RATE_LIMIT=100
COVERR_RATE_LIMIT=100

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=1.0